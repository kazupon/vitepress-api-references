{
  "name": "vitepress-api-references",
  "version": "0.0.0",
  "description": "Enable JSDoc API Reference",
  "homepage": "https://github.com/kazupon/vitepress-api-references#readme",
  "bugs": {
    "url": "https://github.com/kazupon/vitepress-api-references/issues"
  },
  "license": "MIT",
  "author": {
    "name": "kazuya kawaguchi",
    "email": "kawakazu80@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kazupon/vitepress-api-references.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "knip": "knip",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check && knip",
    "prepublishOnly": "vp run build",
    "release": "bumpp --commit \"release: v%s\" --all --push --tag",
    "changelog": "gh-changelogen --repo=kazupon/vitepress-api-references",
    "prepare": "vp config"
  },
  "dependencies": {
    "obug": "^2.1.2"
  },
  "devDependencies": {
    "@kazupon/eslint-plugin": "^0.7.1",
    "@kazupon/vp-config": "^0.2.0",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "bumpp": "^11.1.0",
    "gh-changelogen": "^0.2.8",
    "knip": "^6.16.0",
    "pkg-pr-new": "^0.0.75",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">= 22"
  },
  "packageManager": "pnpm@11.5.2"
}
