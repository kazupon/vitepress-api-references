{
  "name": "vitepress-api-references",
  "version": "0.2.2",
  "description": "Enable JSDoc API Reference for VitePress",
  "keywords": [
    "api-references",
    "docs",
    "documentation",
    "markdown",
    "vitepress"
  ],
  "homepage": "https://github.com/kazupon/vitepress-api-references#readme",
  "bugs": {
    "url": "https://github.com/kazupon/vitepress-api-references/issues"
  },
  "license": "MIT",
  "author": {
    "name": "kazuya kawaguchi",
    "email": "kawakazu80@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kazupon/vitepress-api-references.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "knip": "knip",
    "dev": "vp pack --watch",
    "docs:build": "vp exec vitepress build docs",
    "docs:preview": "vp exec vitepress preview docs",
    "docs:dev": "vp exec vitepress dev docs",
    "docs:standalone": "node standalone/generate.ts",
    "test": "vp test",
    "test:fixtures": "vp exec vitepress build tests/fixtures/basic/docs",
    "check": "vp check && knip",
    "prepublishOnly": "vp run build",
    "release": "bumpp --commit \"release: v%s\" --all --push --tag",
    "changelog": "gh-changelogen --repo=kazupon/vitepress-api-references",
    "prepare": "vp config"
  },
  "dependencies": {
    "@ox-content/napi": "^2.69.0"
  },
  "devDependencies": {
    "@kazupon/vp-config": "^0.3.2",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260605.1",
    "bumpp": "^11.1.0",
    "gh-changelogen": "^0.2.8",
    "knip": "^6.16.0",
    "oxc-minify": "^0.134.0",
    "pkg-pr-new": "^0.0.75",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitepress": "2.0.0-alpha.17"
  },
  "peerDependencies": {
    "vite": ">=5",
    "vitepress": ">=2.0.0-alpha.17"
  },
  "engines": {
    "node": ">= 22"
  },
  "packageManager": "pnpm@11.5.2"
}
